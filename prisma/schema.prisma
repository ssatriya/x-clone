model Post {
  id          String   @id @unique @default(cuid())
  user_one_id String
  user_one    User     @relation("userOne", fields: [user_one_id], references: [id], onDelete: Cascade)
  user_two_id String?
  user_two    User?    @relation("userTwo", fields: [user_two_id], references: [id], onDelete: Cascade)
  content     String?  @db.Text()
  image_url   String?  @db.Text()
  views       Int      @default(0)
  post_type   PostType @default(POST)
  is_deleted  Boolean  @default(false)
  createdAt   DateTime @default(now())

  originalPostId String?

  replys  Reply[]
  reposts Repost[]
  likes   Like[]
  User    User?    @relation(fields: [userId], references: [id])
  userId  String?

  @@index([user_one_id])
  @@map("post")
}

enum PostType {
  POST
  REPOST
}

model Reply {
  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post_id String
  post    Post   @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@id([user_id, post_id])
  @@map("reply")
}

enum RepostType {
  REPOST
  QUOTE
}

model Repost {
  user_id     String
  user        User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post_id     String
  post        Post       @relation(fields: [post_id], references: [id], onDelete: Cascade)
  repost_type RepostType

  @@id([user_id, post_id])
  @@map("repost")
}

model Like {
  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post_id String
  post    Post   @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@id([user_id, post_id])
  @@map("like")
}
