// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id         String   @id @unique
  name       String
  username   String   @unique
  bio        String?
  email      String
  avatar     String
  birthdate  String?
  onboarding Boolean  @default(false)
  createdAt  DateTime @default(now())

  auth_sessions Session[]
  keys          Key[]

  // user_followers Followers[] @relation("userFollower")
  // followers      Followers[] @relation("followerId")

  // user_followings Following[] @relation("userFollowing")
  // followings      Following[] @relation("followingId")

  // followers  Relations[] @relation("followers")
  // followings Relations[] @relation("followings")
  followers User[] @relation("follows")
  following User[] @relation("follows")

  posts_user_one Post[]   @relation("userOne")
  posts_user_two Post[]   @relation("userTwo")
  replys         Reply[]
  reposts        Repost[]
  likes          Like[]
  Post           Post[]

  @@index([username])
  @@map("user")
}

model Session {
  id             String @id @unique
  user_id        String
  active_expires BigInt
  idle_expires   BigInt
  user           User   @relation(references: [id], fields: [user_id])

  @@index([user_id])
  @@map("session")
}

model Key {
  id              String  @id @unique
  hashed_password String?
  user_id         String
  user            User    @relation(references: [id], fields: [user_id])

  @@index([user_id])
  @@map("key")
}

